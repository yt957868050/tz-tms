<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.feian.tms.mapper.InstructorMachineTypeMapper">
    
    <resultMap id="InstructorMachineTypeResult" type="com.feian.tms.domain.InstructorMachineType">
        <result property="relationId"        column="relation_id"        />
        <result property="instructorId"      column="instructor_id"      />
        <result property="machineTypeId"     column="machine_type_id"     />
        <result property="isPrimary"         column="is_primary"          />
        <result property="status"            column="status"              />
        <result property="createBy"          column="create_by"           />
        <result property="createTime"        column="create_time"         />
        <result property="updateBy"          column="update_by"           />
        <result property="updateTime"        column="update_time"         />
        <result property="remark"            column="remark"              />
    </resultMap>

    <sql id="selectInstructorMachineTypeVo">
        select relation_id, instructor_id, machine_type_id, is_primary, status, 
               create_by, create_time, update_by, update_time, remark 
        from tms_instructor_machine_type
    </sql>

    <!-- 根据教员ID查询关联的机型 -->
    <select id="selectByInstructorId" parameterType="Long" resultMap="InstructorMachineTypeResult">
        <include refid="selectInstructorMachineTypeVo"/>
        where instructor_id = #{instructorId} and status = '0'
        order by is_primary desc, create_time desc
    </select>

    <!-- 根据教员ID和机型ID查询关联关系 -->
    <select id="selectByInstructorIdAndMachineTypeId" resultMap="InstructorMachineTypeResult">
        <include refid="selectInstructorMachineTypeVo"/>
        where instructor_id = #{instructorId} and machine_type_id = #{machineTypeId} and status = '0'
    </select>

    <!-- 删除教员的所有机型关联 -->
    <delete id="deleteByInstructorId" parameterType="Long">
        delete from tms_instructor_machine_type where instructor_id = #{instructorId}
    </delete>

</mapper>
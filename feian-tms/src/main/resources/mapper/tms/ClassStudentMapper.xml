<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feian.tms.mapper.ClassStudentMapper">


    <delete id="remremoveStudentByIds">
        DELETE FROM tms_class_student
        WHERE student_id IN
        <foreach item="item" index="index" collection="idList"
                 open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>
    <delete id="removeAllByIds">
        DELETE FROM tms_class_student
        WHERE class_student_id IN
        <foreach item="item" index="index" collection="idList"
                 open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

</mapper>
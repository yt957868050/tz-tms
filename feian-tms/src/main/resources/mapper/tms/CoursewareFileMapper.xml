<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feian.tms.mapper.CoursewareFileMapper">


    <delete id="removeByCoursewareIds">
        delete from tms_courseware_file where courseware_id in
            <foreach collection="idList" item="coursewareId" open="(" separator="," close=")">
                #{coursewareId}
               </foreach>
    </delete>
</mapper>
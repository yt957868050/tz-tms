<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feian.tms.mapper.MachineTypeMapper">


    <delete id="deleteIds">
        delete from tms_machine_type where machine_type_id in
        <foreach collection="idList" item="machineTypeId" open="(" separator="," close=")">
            #{machineTypeId}
        </foreach>
    </delete>
</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feian.tms.mapper.MajorMapper">


    <delete id="deleteIds">
        delete from tms_major where major_id in
        <foreach collection="idList" item="majorId" open="(" separator="," close=")">
            #{majorId}
        </foreach>
    </delete>
</mapper>